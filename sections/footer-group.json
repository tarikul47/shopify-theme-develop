{
  "type": "footer",
  "name": "Footer",
  "sections": {
    "footer_content": {
      "type": "footer",
      "blocks": {
        "help_menu": {
          "type": "menu",
          "settings": {
            "menu": "footer",
            "heading": "Need Help?",
            "width": "fill"
          }
        },
        "account_menu": {
          "type": "menu",
          "settings": {
            "menu": "footer",
            "heading": "My Account",
            "width": "fill"
          }
        },
        "newsletter_group": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "flex-start",
            "gap": 12,
            "width": "fill"
          },
          "blocks": {
            "heading": {
              "type": "text",
              "settings": {
                "text": "<h3>Join the Family</h3>",
                "type_preset": "h4"
              }
            },
            "text": {
              "type": "text",
              "settings": {
                "text": "<p>Get exclusive deals and early access to new products.</p>",
                "type_preset": "rte"
              }
            },
            "form": {
              "type": "email-signup",
              "settings": {
                "border_radius": 100,
                "label": "Email Address"
              }
            }
          },
          "block_order": ["heading", "text", "form"]
        }
      },
      "block_order": ["help_menu", "account_menu", "newsletter_group"],
      "settings": {
        "section_width": "page-width",
        "gap": 40,
        "color_scheme": "scheme-1",
        "padding-block-start": 60,
        "padding-block-end": 60
      }
    },
    "footer_bottom": {
      "type": "footer-utilities",
      "blocks": {
        "copyright": {
          "type": "footer-copyright"
        },
        "social": {
          "type": "social-links"
        }
      },
      "block_order": ["copyright", "social"],
      "settings": {
        "section_width": "page-width",
        "padding-block-start": 20,
        "padding-block-end": 40
      }
    }
  },
  "order": ["footer_content", "footer_bottom"]
}
