{
  "type": "header",
  "name": "Header",
  "sections": {
    "announcement_bar": {
      "type": "header-announcements",
      "blocks": {
        "item_1": {
          "type": "_announcement",
          "settings": {
            "text": "FREE SHIPPING ON ORDERS OVER £30",
            "font": "var(--font-body--family)",
            "font_size": "0.75rem",
            "letter_spacing": "0.1em",
            "case": "uppercase"
          }
        }
      },
      "block_order": ["item_1"],
      "settings": {
        "color_scheme": "scheme-1",
        "divider_width": 1,
        "padding-block-start": 10,
        "padding-block-end": 10
      }
    },
    "header_main": {
      "type": "header",
      "blocks": {
        "logo": {
          "type": "_header-logo",
          "settings": {
            "hide_logo_on_home_page": false
          }
        },
        "menu": {
          "type": "_header-menu",
          "settings": {
            "menu": "main-menu",
            "menu_style": "featured_products",
            "type_font_primary_size": "0.9rem",
            "type_case_primary_link": "none"
          }
        }
      },
      "settings": {
        "logo_position": "left",
        "menu_position": "left",
        "menu_row": "bottom",
        "show_search": true,
        "search_position": "right",
        "enable_sticky_header": "always",
        "section_width": "page-width",
        "color_scheme_top": "scheme-1",
        "color_scheme_bottom": "scheme-1"
      }
    }
  },
  "order": ["announcement_bar", "header_main"]
}
